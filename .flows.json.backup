                "exec_pm2"
            ]
        ]
    },
    {
        "id": "f8b7ff80db0eab99",
        "type": "function",
        "z": "b31915b6cc494042",
        "name": "1. Save Data & Query DB",
        "func": "msg.new_face = msg.payload;\n\nif (msg.payload.status !== 'success') {\n    return null;\n}\n\nconst userDir = env.get(\"USERPROFILE\") || \"C:\";\nmsg.database = userDir + \"/saved_faces/face_data.db\";\n\n// AÑADIDO: Ahora también pedimos la columna 'status' de golpe\nmsg.topic = \"SELECT id, embedding, status FROM persons WHERE embedding IS NOT NULL AND embedding != ''\";\n\nreturn msg;",
        "outputs": 1,
        "timeout": 0,
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "x": 150,
        "y": 720,
        "wires": [
