    {
        "id": "2362aaf9df236738",
        "type": "function",
        "z": "b31915b6cc494042",
        "name": "Build SELECT Query",
        "func": "const userDir = env.get(\"USERPROFILE\") || \"C:\";\nmsg.database = userDir + \"/saved_faces/face_data.db\";\n\n// Solo traemos los que están pendientes de revisión\nmsg.topic = \"SELECT id, first_name, last_name, photo_path, status FROM persons WHERE status = 'pending' ORDER BY id ASC\";\nreturn msg;",
        "outputs": 1,
        "timeout": "",
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
        "x": 760,
        "y": 1000,
        "wires": [
            [
                "7d9fc92e9a40898d"
            ]
        ]
    },
    {
        "id": "1952005aed97c097",
        "type": "function",
        "z": "b31915b6cc494042",
        "name": "Send faces_data to UI",
        "func": "msg.topic = 'faces_data';\nreturn msg;",
        "outputs": 1,
        "timeout": "",
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
        "x": 1160,
        "y": 1000,
        "wires": [
            [
                "8a6bdf124879e6ca"
            ]
        ]
    },
    {
        "id": "809e1132288d19f5",
        "type": "function",
        "z": "b31915b6cc494042",
        "name": "Build UPDATE Query",
        "func": "const d = msg.payload;\n\nconst userDir = env.get(\"USERPROFILE\") || \"C:\";\nmsg.database = userDir + \"/saved_faces/face_data.db\";\n\nif (d.status === 'rejected') {\n    // Si lo rechazas, borramos el registro por completo\n    msg.topic = `DELETE FROM persons WHERE id=${d.id}`;\n} else {\n    // Si es identified o blacklisted, lo actualizamos con sus datos\n    const fn = d.first_name || '';\n    const ln = d.last_name || '';\n    msg.topic = `UPDATE persons SET first_name='${fn}', last_name='${ln}', status='${d.status}' WHERE id=${d.id}`;\n}\n\nreturn msg;",
        "outputs": 1,
        "timeout": "",
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
        "x": 760,
        "y": 1080,
        "wires": [
            [
                "daf29bb83d95b5b0"
            ]
        ]
    },
    {
        "id": "8e645c08d5a3df8d",
        "type": "function",
        "z": "b31915b6cc494042",
        "name": "Send save_result to UI",
        "func": "msg.payload = { success: true };\nmsg.topic   = 'save_result';\nreturn msg;",
        "outputs": 1,
        "timeout": "",
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
        "x": 1160,
        "y": 1080,
        "wires": [
            [
                "8a6bdf124879e6ca"
            ]
        ]
    },
