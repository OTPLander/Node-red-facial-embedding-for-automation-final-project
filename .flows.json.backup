    {
        "id": "509c91c6c45ad3a0",
        "type": "function",
        "z": "b31915b6cc494042",
        "name": "Extract Bytes From OPC UA",
        "func": "// 1. Navegamos por la estructura\nif (!msg.payload || !msg.payload.value || !msg.payload.value.value || msg.payload.value.value.value === undefined) {\n    node.error(\"Estructura OPC UA no válida\");\n    return null;\n}\n\nlet rawData = msg.payload.value.value.value;\nlet dataArray = [];\n\n// 2. EXTRACCIÓN A PRUEBA DE BOMBAS\n// Filtramos según el formato en el que OPC UA haya escupido el buffer\nif (Buffer.isBuffer(rawData)) {\n    dataArray = Array.from(rawData);\n} else if (Array.isArray(rawData)) {\n    dataArray = rawData;\n} else if (rawData.data && Array.isArray(rawData.data)) {\n    // Formato de Buffer serializado { type: 'Buffer', data: [255, 216...] }\n    dataArray = rawData.data;\n} else if (typeof rawData === 'object') {\n    // Formato de Diccionario o TypedArray {\"0\": 255, \"1\": 216...}\n    if (rawData.length !== undefined) {\n        dataArray = Array.from(rawData);\n    } else {\n        dataArray = Object.values(rawData);\n    }\n}\n\n// Chivato por si acaso\nif (dataArray.length === 0) {\n    node.warn(\"El array está vacío. El formato raro recibido es: \" + typeof rawData);\n    return null;\n}\n\n// 3. BUSCAR EL FINAL DEL JPG (FF D9 -> 255 217)\nlet endIndex = dataArray.length;\n\nfor (let i = 0; i < dataArray.length - 1; i++) {\n    // El & 0xFF convierte los SInt (bytes con signo como -1) a USInt (255) mágicamente\n    let byte1 = dataArray[i] & 0xFF;\n    let byte2 = dataArray[i+1] & 0xFF;\n\n    if (byte1 === 255 && byte2 === 217) {\n        endIndex = i + 2; \n        break; \n    }\n}\n\n// 4. Recortamos la basura (los ceros del PLC) y lo pasamos al formato exacto de Flask\nlet byteDict = {};\nfor(let i = 0; i < endIndex; i++) {\n    byteDict[i] = dataArray[i] & 0xFF;\n}\n\n// Sobrescribimos el payload y lo enviamos al nodo HTTP Request\nmsg.payload = { image_bytes: byteDict };\nreturn msg;",
        "outputs": 1,
