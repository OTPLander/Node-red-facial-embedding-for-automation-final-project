        "height": "14",
        "head": "",
        "format": "<template>\n  <div class=\"face-registry\">\n    <div class=\"header\">\n      <div class=\"header-left\">\n        <span class=\"badge\" v-if=\"faces.length > 0\">{{ currentIndex + 1 }} / {{ faces.length }}</span>\n        <span class=\"badge empty\" v-else>No records</span>\n      </div>\n      <h1 class=\"title\">FACE <span>REGISTRY</span></h1>\n      <div class=\"header-right\">\n        <button class=\"btn-nav\" @click=\"goTo('/all-records')\">&#128451; VIEW RECORDS</button>\n        <span class=\"status-dot\" :class=\"faces[currentIndex] && faces[currentIndex].status\"></span>\n        <span class=\"status-label\">{{ faces[currentIndex] ? faces[currentIndex].status : '—' }}</span>\n      </div>\n    </div>\n    <div class=\"main\" v-if=\"faces.length > 0\">\n      <div class=\"image-panel\">\n        <button class=\"nav-btn\" @click=\"prev\" :disabled=\"currentIndex === 0\">&#8592;</button>\n        <div class=\"image-wrapper\">\n          <img v-if=\"faces[currentIndex].photo_path\" :src=\"'/faces/' + getFilename(faces[currentIndex].photo_path)\"\n               @error=\"onImgError($event)\"\n               class=\"face-img\" />\n          <div class=\"img-overlay\" :class=\"faces[currentIndex].status\">{{ faces[currentIndex].status }}</div>\n        </div>\n        <button class=\"nav-btn\" @click=\"next\" :disabled=\"currentIndex === faces.length - 1\">&#8594;</button>\n      </div>\n      <div class=\"form-panel\">\n        <div class=\"field-row\">\n          <div class=\"field\">\n            <label>FIRST NAME</label>\n            <input v-model=\"form.first_name\" placeholder=\"Enter first name\" />\n          </div>\n          <div class=\"field\">\n            <label>LAST NAME</label>\n            <input v-model=\"form.last_name\" placeholder=\"Enter last name\" />\n          </div>\n        </div>\n        <div class=\"field\">\n          <label>RECORD ID</label>\n          <input :value=\"faces[currentIndex].id\" disabled class=\"disabled-input\" />\n        </div>\n        <div class=\"field\">\n          <label>PHOTO PATH</label>\n          <input :value=\"faces[currentIndex].photo_path\" disabled class=\"disabled-input path-input\" />\n        </div>\n        <div class=\"field\">\n          <label>SET STATUS</label>\n          <div class=\"status-selector\">\n            <button v-for=\"s in statuses\" :key=\"s\"\n                    class=\"status-btn\"\n                    :class=\"{ active: form.status === s, [s]: true }\"\n                    @click=\"form.status = s\">{{ s }}\n            </button>\n          </div>\n        </div>\n        <div class=\"actions\">\n          <button class=\"btn-reset\" @click=\"resetForm\">RESET</button>\n          <button class=\"btn-save\" @click=\"save\" :disabled=\"saving\">\n            <span v-if=\"saving\">SAVING...</span>\n            <span v-else>SAVE RECORD</span>\n          </button>\n        </div>\n        <div class=\"toast\" :class=\"{ visible: toast.show, [toast.type]: true }\">{{ toast.message }}</div>\n      </div>\n    </div>\n    <div class=\"empty-state\" v-else>\n      <div class=\"empty-icon\">&#9711;</div>\n      <p>No pending faces found in the database.</p>\n      <button class=\"btn-save empty-refresh-btn\" @click=\"loadFaces\">REFRESH</button>\n    </div>\n  </div>\n</template>\n\n<script>\nexport default {\n  data() {\n    return {\n      faces: [],\n      currentIndex: 0,\n      statuses: ['pending', 'identified', 'rejected', 'blacklisted'],\n      form: { first_name: '', last_name: '', status: 'pending' },\n      saving: false,\n      toast: { show: false, message: '', type: 'success' }\n    };\n  },\n  watch: {\n    msg(newMsg) {\n      if (!newMsg) return;\n      if (newMsg.topic === 'faces_data') {\n        this.faces = newMsg.payload || [];\n        this.currentIndex = 0;\n        this.syncForm();\n        this.saving = false;\n      } else if (newMsg.topic === 'save_result') {\n        this.saving = false;\n        if (newMsg.payload && newMsg.payload.success) {\n          this.showToast('Record updated!', 'success');\n          this.faces.splice(this.currentIndex, 1);\n          if (this.currentIndex >= this.faces.length && this.currentIndex > 0) {\n              this.currentIndex--;\n          }\n          this.syncForm();\n        } else {\n          this.showToast('Error saving record.', 'error');\n        }\n      }\n    }\n  },\n  mounted() { this.loadFaces(); },\n  methods: {\n    loadFaces() { this.send({ topic: 'load_faces', payload: null }); },\n    prev() { if (this.currentIndex > 0) { this.currentIndex--; this.syncForm(); } },\n    next() { if (this.currentIndex < this.faces.length - 1) { this.currentIndex++; this.syncForm(); } },\n    syncForm() {\n      const f = this.faces[this.currentIndex];\n      if (f) {\n        this.form.first_name = f.first_name || '';\n        this.form.last_name  = f.last_name  || '';\n        this.form.status     = f.status     || 'pending';\n      }\n    },\n    save() {\n      const face = this.faces[this.currentIndex];\n      this.saving = true;\n      this.send({ topic: 'save_face', payload: { id: face.id, first_name: this.form.first_name, last_name: this.form.last_name, status: this.form.status } });\n    },\n    resetForm() { this.syncForm(); },\n    getFilename(path) {\n      if (!path) return '';\n      return path.replace(/\\\\/g, '/').split('/').pop();\n    },\n    onImgError(e) {\n      e.target.src = 'data:image/svg+xml,<svg xmlns=\"http://www.w3.org/2000/svg\" width=\"200\" height=\"200\"><rect fill=\"%23111\" width=\"200\" height=\"200\"/><text x=\"50%\" y=\"50%\" fill=\"%23555\" font-size=\"14\" text-anchor=\"middle\" dy=\".3em\">NO IMAGE</text></svg>';\n    },\n    showToast(message, type) {\n      this.toast = { show: true, message, type };\n      setTimeout(() => { this.toast.show = false; }, 3000);\n    },\n    goTo(path) {\n      window.location.href = '/dashboard' + path;\n    }\n  }\n};\n</script>\n\n<style>\n@import url('https://fonts.googleapis.com/css2?family=Share+Tech+Mono&family=Exo+2:wght@300;600;800&display=swap');\n.face-registry * { box-sizing: border-box; margin: 0; padding: 0; }\n.face-registry { \n  background: #0a0a0f; \n  color: #c8d8e8; \n  font-family: 'Exo 2', sans-serif; \n  position: fixed; \n  top: 0; left: 0; right: 0; bottom: 0; \n  z-index: 100; \n  padding: 40px 50px; \n  overflow-y: auto; \n  display: flex; \n  flex-direction: column; \n}\n.face-registry::before { content: ''; position: absolute; top: 0; left: 0; right: 0; bottom: 0; background: repeating-linear-gradient(0deg, transparent, transparent 39px, #111827 40px); pointer-events: none; opacity: 0.25; }\n.header { display: flex; align-items: center; width: 100%; margin-bottom: 40px; padding-bottom: 20px; border-bottom: 1px solid #1e2d40; position: relative; z-index: 2; }\n.header-left { flex: 1; display: flex; justify-content: flex-start; }\n.header-right { flex: 1; display: flex; align-items: center; justify-content: flex-end; gap: 12px; }\n.title { flex: 0 0 auto; text-align: center; font-size: 1.8rem; font-weight: 800; letter-spacing: 0.25em; text-transform: uppercase; color: #e0eaf5; }\n.title span { color: #38bdf8; }\n.badge { font-family: 'Share Tech Mono', monospace; font-size: 0.85rem; background: #0f2035; border: 1px solid #1e3a55; color: #38bdf8; padding: 6px 14px; border-radius: 2px; letter-spacing: 0.1em; }\n.badge.empty { color: #555; border-color: #222; }\n.btn-nav { background: #0f2035; border: 1px solid #38bdf8; color: #38bdf8; font-family: 'Share Tech Mono', monospace; font-size: 0.8rem; letter-spacing: 0.15em; padding: 8px 16px; border-radius: 3px; cursor: pointer; text-transform: uppercase; transition: all 0.2s; margin-right: 15px; }\n.btn-nav:hover { background: #38bdf8; color: #050d16; box-shadow: 0 0 10px #38bdf866; }\n.status-dot { width: 12px; height: 12px; border-radius: 50%; background: #555; }\n.status-dot.pending { background: #f59e0b; box-shadow: 0 0 8px #f59e0b88; }\n.status-dot.identified { background: #38bdf8; box-shadow: 0 0 8px #38bdf888; }\n.status-dot.blacklisted { background: #a855f7; box-shadow: 0 0 8px #a855f788; }\n.status-dot.rejected { background: #ef4444; box-shadow: 0 0 8px #ef444488; }\n.status-label { font-family: 'Share Tech Mono', monospace; font-size: 0.8rem; text-transform: uppercase; letter-spacing: 0.12em; color: #6b8aaa; }\n.main { display: flex; gap: 50px; align-items: center; justify-content: center; flex: 1; position: relative; z-index: 2; }\n.image-panel { display: flex; align-items: center; gap: 15px; flex-shrink: 0; }\n.image-wrapper { position: relative; width: 280px; height: 320px; border: 1px solid #1e2d40; border-radius: 3px; overflow: hidden; background: #060b12; box-shadow: 0 10px 30px rgba(0,0,0,0.5); }\n.face-img { width: 100%; height: 100%; object-fit: cover; display: block; filter: contrast(1.05) saturate(0.9); transition: filter 0.3s; }\n.image-wrapper:hover .face-img { filter: contrast(1.1) saturate(1); }\n.img-overlay { position: absolute; bottom: 0; left: 0; right: 0; padding: 8px 0; text-align: center; font-family: 'Share Tech Mono', monospace; font-size: 0.75rem; letter-spacing: 0.2em; text-transform: uppercase; background: rgba(0,0,0,0.72); color: #555; }\n.img-overlay.pending { color: #f59e0b; }\n.img-overlay.identified { color: #38bdf8; }\n.img-overlay.blacklisted { color: #a855f7; }\n.img-overlay.rejected { color: #ef4444; }\n.nav-btn { background: #0f1e2e; border: 1px solid #1e3a55; color: #38bdf8; width: 44px; height: 44px; border-radius: 3px; font-size: 1.4rem; cursor: pointer; transition: background 0.2s, transform 0.1s; flex-shrink: 0; }\n.nav-btn:hover:not(:disabled) { background: #162840; transform: scale(1.08); }\n.nav-btn:disabled { opacity: 0.2; cursor: default; }\n.form-panel { flex: 0 1 500px; display: flex; flex-direction: column; gap: 20px; }\n.field-row { display: flex; gap: 18px; }\n.field { display: flex; flex-direction: column; gap: 8px; flex: 1; }\n.field label { font-family: 'Share Tech Mono', monospace; font-size: 0.75rem; letter-spacing: 0.2em; color: #3a5a7a; text-transform: uppercase; }\n.field input { background: #060d16; border: 1px solid #1a2e44; color: #c8d8e8; padding: 12px 16px; font-family: 'Exo 2', sans-serif; font-size: 1rem; border-radius: 3px; outline: none; transition: border-color 0.2s, box-shadow 0.2s; }\n.field input:focus { border-color: #38bdf8; box-shadow: 0 0 0 2px #38bdf820; }\n.disabled-input { opacity: 0.4; cursor: not-allowed; }\n.path-input { font-family: 'Share Tech Mono', monospace; font-size: 0.8rem; }\n.status-selector { display: flex; gap: 10px; flex-wrap: wrap; }\n.status-btn { padding: 10px 18px; border-radius: 3px; border: 1px solid #1e2d40; background: #060d16; color: #4a6a8a; font-family: 'Share Tech Mono', monospace; font-size: 0.75rem; letter-spacing: 0.15em; text-transform: uppercase; cursor: pointer; transition: all 0.2s; }\n.status-btn:hover { border-color: #38bdf8; color: #38bdf8; }\n.status-btn.active.pending { background: #2d1e00; border-color: #f59e0b; color: #f59e0b; }\n.status-btn.active.identified { background: #002030; border-color: #38bdf8; color: #38bdf8; }\n.status-btn.active.blacklisted { background: #2e1065; border-color: #a855f7; color: #a855f7; }\n.status-btn.active.rejected { background: #200010; border-color: #ef4444; color: #ef4444; }\n.actions { display: flex; gap: 15px; margin-top: 10px; }\n.btn-save { flex: 1; padding: 14px; background: #38bdf8; color: #050d16; font-family: 'Exo 2', sans-serif; font-weight: 800; font-size: 0.9rem; letter-spacing: 0.2em; text-transform: uppercase; border: none; border-radius: 3px; cursor: pointer; transition: background 0.2s, transform 0.1s; }\n.btn-save:hover:not(:disabled) { background: #7dd3f8; transform: translateY(-2px); }\n.btn-save:disabled { opacity: 0.5; cursor: not-allowed; }\n.btn-reset { padding: 14px 24px; background: transparent; border: 1px solid #1e3a55; color: #4a6a8a; font-family: 'Exo 2', sans-serif; font-weight: 600; font-size: 0.9rem; letter-spacing: 0.15em; text-transform: uppercase; border-radius: 3px; cursor: pointer; transition: all 0.2s; }\n.btn-reset:hover { border-color: #38bdf8; color: #38bdf8; }\n.empty-refresh-btn { flex: 0 0 auto !important; width: auto !important; padding: 14px 50px !important; }\n.toast { position: fixed; bottom: 30px; right: 40px; padding: 12px 24px; border-radius: 3px; font-family: 'Share Tech Mono', monospace; font-size: 0.85rem; letter-spacing: 0.12em; opacity: 0; transform: translateY(10px); transition: opacity 0.3s, transform 0.3s; pointer-events: none; z-index: 200; }\n.toast.visible { opacity: 1; transform: translateY(0); }\n.toast.success { background: #002010; border: 1px solid #22c55e; color: #22c55e; }\n.toast.error { background: #200010; border: 1px solid #ef4444; color: #ef4444; }\n.empty-state { display: flex; flex-direction: column; align-items: center; justify-content: center; gap: 20px; flex: 1; color: #2a4060; position: relative; z-index: 2; }\n.empty-icon { font-size: 4rem; }\n.empty-state p { font-family: 'Share Tech Mono', monospace; font-size: 0.9rem; letter-spacing: 0.1em; }\n</style>",
        "storeOutMessages": true,
        "passthru": true,
        "resendOnRefresh": true,
        "templateScope": "widget:page",
        "className": "",
        "x": 340,
        "y": 1040,
        "wires": [
            [
                "58e521646670c8fb"
            ]
        ]
    },
    {
        "id": "e7b7f7028c740910",
        "type": "ui-template",
        "z": "b31915b6cc494042",
        "group": "",
        "page": "face_table_page",
        "ui": "",
        "name": "All Records Table",
        "order": 1,
        "width": "24",
        "height": "14",
        "head": "",
        "format": "<template>\n  <div class=\"records-view\">\n    <div class=\"rv-header\">\n      <div class=\"rv-header-left\">\n        <button class=\"btn-nav\" @click=\"goTo('/registry')\">&#128247; BACK TO REGISTRY</button>\n      </div>\n      <div class=\"rv-title\">ALL <span>RECORDS</span></div>\n      <div class=\"rv-header-right\">\n        <input class=\"rv-search\" v-model=\"search\" placeholder=\"Search name, status...\" />\n        <button class=\"rv-refresh\" @click=\"load\">&#8635; REFRESH</button>\n        <span class=\"rv-count\">{{ filtered.length }} / {{ rows.length }} rows</span>\n      </div>\n    </div>\n    <div class=\"rv-table-wrap\">\n      <table class=\"rv-table\" v-if=\"rows.length > 0\">\n        <thead>\n          <tr>\n            <th @click=\"sortBy('id')\"         class=\"sortable\">ID     <span class=\"sort-icon\">{{ sortIcon('id') }}</span></th>\n            <th @click=\"sortBy('first_name')\" class=\"sortable\">FIRST  <span class=\"sort-icon\">{{ sortIcon('first_name') }}</span></th>\n            <th @click=\"sortBy('last_name')\"  class=\"sortable\">LAST   <span class=\"sort-icon\">{{ sortIcon('last_name') }}</span></th>\n            <th @click=\"sortBy('status')\"     class=\"sortable\">STATUS <span class=\"sort-icon\">{{ sortIcon('status') }}</span></th>\n            <th>PHOTO PATH</th>\n            <th>EMBEDDING</th>\n          </tr>\n        </thead>\n        <tbody>\n          <tr v-for=\"row in paginated\" :key=\"row.id\" :class=\"'row-' + row.status\" @click=\"openModal(row)\" class=\"clickable-row\" title=\"Click to view photo\">\n            <td class=\"mono\">{{ row.id }}</td>\n            <td>{{ row.first_name || '—' }}</td>\n            <td>{{ row.last_name  || '—' }}</td>\n            <td><span class=\"pill\" :class=\"row.status\">{{ row.status }}</span></td>\n            <td class=\"mono path-cell\">{{ truncate(row.photo_path, 38) }}</td>\n            <td class=\"mono emb-cell\" >{{ truncate(row.embedding,  30) }}</td>\n          </tr>\n        </tbody>\n      </table>\n      <div class=\"rv-empty\" v-else><span>&#9711;</span><p>No records found.</p></div>\n    </div>\n    <div class=\"rv-pagination\" v-if=\"totalPages > 1\">\n      <button class=\"pg-btn\" @click=\"page = 1\"          :disabled=\"page === 1\">&#171;</button>\n      <button class=\"pg-btn\" @click=\"page--\"            :disabled=\"page === 1\">&#8249;</button>\n      <span class=\"pg-info\">Page {{ page }} of {{ totalPages }}</span>\n      <button class=\"pg-btn\" @click=\"page++\"            :disabled=\"page === totalPages\">&#8250;</button>\n      <button class=\"pg-btn\" @click=\"page = totalPages\" :disabled=\"page === totalPages\">&#187;</button>\n      <select class=\"pg-size\" v-model=\"pageSize\">\n        <option :value=\"10\">10 / page</option>\n        <option :value=\"25\">25 / page</option>\n        <option :value=\"50\">50 / page</option>\n      </select>\n    </div>\n\n    <!-- MODAL PARA LA IMAGEN -->\n    <div class=\"modal-overlay\" v-if=\"selectedRecord\" @click.self=\"closeModal\">\n      <div class=\"modal-content\">\n        <button class=\"modal-close\" @click=\"closeModal\">&times;</button>\n        <div class=\"modal-header\">\n          <h2>{{ selectedRecord.first_name || 'Unknown' }} {{ selectedRecord.last_name || 'Face' }}</h2>\n          <span class=\"pill\" :class=\"selectedRecord.status\">{{ selectedRecord.status }}</span>\n        </div>\n        <div class=\"modal-body\">\n          <img :src=\"'/faces/' + getFilename(selectedRecord.photo_path)\"\n               @error=\"onImgError($event)\"\n               class=\"modal-img\" />\n        </div>\n        <div class=\"modal-footer mono\">\n          ID: {{ selectedRecord.id }}\n        </div>\n      </div>\n    </div>\n  </div>\n</template>\n\n<script>\nexport default {\n  data() {\n    return { \n      rows: [], \n      search: '', \n      sortKey: 'id', \n      sortDir: 1, \n      page: 1, \n      pageSize: 10, \n      selectedRecord: null \n    };\n  },\n  computed: {\n    filtered() {\n      const q = this.search.toLowerCase();\n      const data = q ? this.rows.filter(r =>\n        (r.first_name||'').toLowerCase().includes(q) ||\n        (r.last_name||'').toLowerCase().includes(q)  ||\n        (r.status||'').toLowerCase().includes(q)     ||\n        String(r.id).includes(q)\n      ) : this.rows;\n      return [...data].sort((a, b) => {\n        const av = a[this.sortKey] ?? '';\n        const bv = b[this.sortKey] ?? '';\n        return av < bv ? -this.sortDir : av > bv ? this.sortDir : 0;\n      });\n    },\n    totalPages() { return Math.max(1, Math.ceil(this.filtered.length / this.pageSize)); },\n    paginated() { const s = (this.page - 1) * this.pageSize; return this.filtered.slice(s, s + this.pageSize); }\n  },\n  watch: {\n    msg(newMsg) {\n      if (!newMsg) return;\n      if (newMsg.topic === 'table_data') {\n        this.rows = newMsg.payload || [];\n      }\n    },\n    search()   { this.page = 1; },\n    pageSize() { this.page = 1; }\n  },\n  mounted() {\n    this.load();\n    // Cerrar modal con la tecla ESC\n    window.addEventListener('keydown', this.handleKeydown);\n  },\n  unmounted() {\n    window.removeEventListener('keydown', this.handleKeydown);\n  },\n  methods: {\n    load() { this.send({ topic: 'load_table', payload: null }); },\n    sortBy(key) {\n      if (this.sortKey === key) { this.sortDir *= -1; }\n      else { this.sortKey = key; this.sortDir = 1; }\n    },\n    sortIcon(key) { if (this.sortKey !== key) return '⇅'; return this.sortDir === 1 ? '↑' : '↓'; },\n    truncate(str, n) { if (!str) return '—'; return str.length > n ? str.slice(0, n) + '…' : str; },\n    goTo(path) {\n      window.location.href = '/dashboard' + path;\n    },\n    openModal(row) {\n      this.selectedRecord = row;\n    },\n    closeModal() {\n      this.selectedRecord = null;\n    },\n    handleKeydown(e) {\n      if (e.key === 'Escape' && this.selectedRecord) {\n        this.closeModal();\n      }\n    },\n    getFilename(path) {\n      if (!path) return '';\n      return path.replace(/\\\\/g, '/').split('/').pop();\n    },\n    onImgError(e) {\n      e.target.src = 'data:image/svg+xml,<svg xmlns=\"http://www.w3.org/2000/svg\" width=\"200\" height=\"200\"><rect fill=\"%23111\" width=\"200\" height=\"200\"/><text x=\"50%\" y=\"50%\" fill=\"%23555\" font-size=\"14\" text-anchor=\"middle\" dy=\".3em\">NO IMAGE</text></svg>';\n    }\n  }\n};\n</script>\n\n<style>\n@import url('https://fonts.googleapis.com/css2?family=Share+Tech+Mono&family=Exo+2:wght@300;600;800&display=swap');\n.records-view * { box-sizing: border-box; margin: 0; padding: 0; }\n.records-view { \n  background: #0a0a0f; color: #c8d8e8; font-family: 'Exo 2', sans-serif; \n  position: fixed; top: 0; left: 0; right: 0; bottom: 0; z-index: 100; \n  padding: 40px 50px; overflow-y: auto; display: flex; flex-direction: column; gap: 20px; \n}\n.records-view::before { content: ''; position: absolute; inset: 0; background: repeating-linear-gradient(0deg, transparent, transparent 39px, #111827 40px); pointer-events: none; opacity: 0.2; }\n.rv-header { display: flex; align-items: center; justify-content: space-between; width: 100%; padding-bottom: 20px; border-bottom: 1px solid #1e2d40; position: relative; z-index: 2; }\n.rv-header-left { flex: 1; display: flex; justify-content: flex-start; }\n.rv-header-right { flex: 1; display: flex; justify-content: flex-end; align-items: center; gap: 15px; flex-wrap: wrap; }\n.rv-title { flex: 0 0 auto; text-align: center; font-size: 1.8rem; font-weight: 800; letter-spacing: 0.25em; text-transform: uppercase; color: #e0eaf5; }\n.rv-title span { color: #38bdf8; }\n.btn-nav { background: #0f2035; border: 1px solid #38bdf8; color: #38bdf8; font-family: 'Share Tech Mono', monospace; font-size: 0.8rem; letter-spacing: 0.15em; padding: 9px 18px; border-radius: 3px; cursor: pointer; text-transform: uppercase; transition: all 0.2s; }\n.btn-nav:hover { background: #38bdf8; color: #050d16; box-shadow: 0 0 10px #38bdf866; }\n.rv-search { background: #060d16; border: 1px solid #1a2e44; color: #c8d8e8; padding: 9px 14px; font-family: 'Exo 2', sans-serif; font-size: 0.9rem; border-radius: 3px; outline: none; width: 280px; transition: border-color 0.2s; }\n.rv-search:focus { border-color: #38bdf8; }\n.rv-search::placeholder { color: #2a4060; }\n.rv-refresh { background: transparent; border: 1px solid #1e3a55; color: #38bdf8; font-family: 'Share Tech Mono', monospace; font-size: 0.8rem; letter-spacing: 0.12em; padding: 9px 16px; border-radius: 3px; cursor: pointer; transition: background 0.2s; }\n.rv-refresh:hover { background: #0f2035; }\n.rv-count { font-family: 'Share Tech Mono', monospace; font-size: 0.8rem; color: #3a5a7a; letter-spacing: 0.1em; padding-left: 10px; }\n.rv-table-wrap { overflow-x: auto; flex: 1; position: relative; z-index: 2; background: rgba(10, 14, 26, 0.6); border-radius: 4px; padding: 10px; }\n.rv-table { width: 100%; border-collapse: collapse; font-size: 0.95rem; }\n.rv-table thead tr { border-bottom: 2px solid #1e3a55; }\n.rv-table th { font-family: 'Share Tech Mono', monospace; font-size: 0.75rem; letter-spacing: 0.2em; color: #3a5a7a; text-transform: uppercase; padding: 14px 18px; text-align: left; white-space: nowrap; user-select: none; }\n.rv-table th.sortable { cursor: pointer; }\n.rv-table th.sortable:hover { color: #38bdf8; }\n.sort-icon { margin-left: 6px; font-size: 0.75rem; opacity: 0.6; }\n.rv-table tbody tr { border-bottom: 1px solid #0f1a28; transition: background 0.15s; }\n.rv-table tbody tr:hover { background: #0d1a28; }\n.clickable-row { cursor: pointer; }\n.clickable-row:hover td { color: #fff; }\n.rv-table tbody tr.row-pending    { border-left: 3px solid #f59e0b33; }\n.rv-table tbody tr.row-identified { border-left: 3px solid #38bdf833; }\n.rv-table tbody tr.row-blacklisted { border-left: 3px solid #a855f733; }\n.rv-table tbody tr.row-rejected   { border-left: 3px solid #ef444433; }\n.rv-table td { padding: 14px 18px; color: #8aaac8; vertical-align: middle; transition: color 0.2s; }\n.rv-table td.mono { font-family: 'Share Tech Mono', monospace; font-size: 0.85rem; }\n.path-cell, .emb-cell { color: #3a5a7a; max-width: 320px; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }\n.pill { display: inline-block; padding: 4px 12px; border-radius: 3px; font-family: 'Share Tech Mono', monospace; font-size: 0.7rem; letter-spacing: 0.15em; text-transform: uppercase; border: 1px solid #1e2d40; color: #555; }\n.pill.pending    { background: #2d1e0088; border-color: #f59e0b66; color: #f59e0b; }\n.pill.identified { background: #00203088; border-color: #38bdf866; color: #38bdf8; }\n.pill.blacklisted { background: #2e106588; border-color: #a855f766; color: #a855f7; }\n.pill.rejected   { background: #20001088; border-color: #ef444466; color: #ef4444; }\n.rv-empty { display: flex; flex-direction: column; align-items: center; justify-content: center; gap: 15px; min-height: 350px; color: #2a4060; }\n.rv-empty span { font-size: 3rem; }\n.rv-empty p { font-family: 'Share Tech Mono', monospace; font-size: 0.9rem; letter-spacing: 0.1em; }\n.rv-pagination { display: flex; align-items: center; gap: 8px; justify-content: flex-end; padding-top: 15px; border-top: 1px solid #1e2d40; position: relative; z-index: 2; }\n.pg-btn { background: #0f1e2e; border: 1px solid #1e3a55; color: #38bdf8; width: 36px; height: 36px; border-radius: 3px; font-size: 1rem; cursor: pointer; transition: background 0.2s; }\n.pg-btn:hover:not(:disabled) { background: #162840; }\n.pg-btn:disabled { opacity: 0.25; cursor: default; }\n.pg-info { font-family: 'Share Tech Mono', monospace; font-size: 0.8rem; color: #3a5a7a; letter-spacing: 0.1em; padding: 0 10px; }\n.pg-size { background: #060d16; border: 1px solid #1a2e44; color: #6b8aaa; font-family: 'Share Tech Mono', monospace; font-size: 0.8rem; padding: 6px 10px; border-radius: 3px; margin-left: 12px; cursor: pointer; }\n\n/* MODAL STYLES */\n.modal-overlay { position: fixed; top: 0; left: 0; right: 0; bottom: 0; background: rgba(0, 0, 0, 0.85); display: flex; justify-content: center; align-items: center; z-index: 999; backdrop-filter: blur(4px); }\n.modal-content { background: #0a0a0f; border: 1px solid #1e2d40; border-radius: 4px; padding: 25px; position: relative; max-width: 400px; width: 100%; box-shadow: 0 20px 50px rgba(0,0,0,0.5); }\n.modal-close { position: absolute; top: 12px; right: 15px; background: transparent; border: none; color: #6b8aaa; font-size: 1.8rem; cursor: pointer; transition: color 0.2s; }\n.modal-close:hover { color: #ef4444; }\n.modal-header { display: flex; flex-direction: column; gap: 10px; margin-bottom: 20px; padding-right: 20px; }\n.modal-header h2 { font-size: 1.4rem; margin: 0; color: #e0eaf5; text-transform: uppercase; font-family: 'Exo 2', sans-serif; }\n.modal-img { width: 100%; height: auto; max-height: 400px; object-fit: cover; border-radius: 3px; border: 1px solid #1e2d40; display: block; }\n.modal-footer { margin-top: 15px; font-size: 0.75rem; color: #3a5a7a; text-align: center; }\n</style>",
