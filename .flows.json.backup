        "sqlquery": "msg.topic",
        "dbName": "msg.database",
        "db": "",
        "sql": "",
        "name": "Local Database",
        "x": 890,
        "y": 220,
        "wires": [
            [
                "b7a0caa963dc0433"
            ]
        ]
    },
