    {
        "id": "ae5fe517035956e1",
        "type": "function",
        "z": "b31915b6cc494042",
        "name": "Extract Bytes for Python",
        "func": "let buf = msg.payload;\nlet byteDict = {};\nfor(let i = 0; i < buf.length; i++) {\n    byteDict[i] = buf[i];\n}\nmsg.payload = { image_bytes: byteDict };\nreturn msg;",
        "outputs": 1,
        "x": 690,
        "y": 600,
        "wires": [
            [
                "1ce8cc543c06cadc"
            ]
        ]
    },
    {
        "id": "1ce8cc543c06cadc",
        "type": "http request",
        "z": "b31915b6cc494042",
        "name": "POST /embed_and_reconstruct",
        "method": "POST",
        "ret": "obj",
        "paytoqs": "ignore",
        "url": "http://localhost:5005/embed_and_reconstruct",
        "tls": "",
        "persist": false,
        "proxy": "",
        "insecureHTTPParser": false,
        "authType": "",
        "senderr": false,
        "headers": [
            {
                "keyType": "other",
                "keyValue": "Content-Type",
                "valueType": "other",
                "valueValue": "application/json"
            }
        ],
        "x": 1050,
