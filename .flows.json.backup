    {
        "id": "33a12c682079c1d7",
        "type": "ui-template",
        "z": "b31915b6cc494042",
        "group": "face_table_group",
        "page": "",
        "ui": "",
        "name": "All Records Table",
        "order": 1,
        "width": "24",
        "height": "14",
        "head": "",
        "format": "<template>\n  <div class=\"records-view\">\n    <div class=\"rv-header\">\n      <div class=\"rv-title\">ALL <span>RECORDS</span></div>\n      <div class=\"rv-controls\">\n        <input class=\"rv-search\" v-model=\"search\" placeholder=\"Search name, status...\" />\n        <button class=\"rv-refresh\" @click=\"load\">&#8635; REFRESH</button>\n        <span class=\"rv-count\">{{ filtered.length }} / {{ rows.length }} rows</span>\n      </div>\n    </div>\n    <div class=\"rv-table-wrap\">\n      <table class=\"rv-table\" v-if=\"rows.length > 0\">\n        <thead>\n          <tr>\n            <th @click=\"sortBy('id')\"         class=\"sortable\">ID     <span class=\"sort-icon\">{{ sortIcon('id') }}</span></th>\n            <th @click=\"sortBy('first_name')\" class=\"sortable\">FIRST  <span class=\"sort-icon\">{{ sortIcon('first_name') }}</span></th>\n            <th @click=\"sortBy('last_name')\"  class=\"sortable\">LAST   <span class=\"sort-icon\">{{ sortIcon('last_name') }}</span></th>\n            <th @click=\"sortBy('status')\"     class=\"sortable\">STATUS <span class=\"sort-icon\">{{ sortIcon('status') }}</span></th>\n            <th>PHOTO PATH</th>\n            <th>EMBEDDING</th>\n          </tr>\n        </thead>\n        <tbody>\n          <tr v-for=\"row in paginated\" :key=\"row.id\" :class=\"'row-' + row.status\">\n            <td class=\"mono\">{{ row.id }}</td>\n            <td>{{ row.first_name || '—' }}</td>\n            <td>{{ row.last_name  || '—' }}</td>\n            <td><span class=\"pill\" :class=\"row.status\">{{ row.status }}</span></td>\n            <td class=\"mono path-cell\" :title=\"row.photo_path\">{{ truncate(row.photo_path, 38) }}</td>\n            <td class=\"mono emb-cell\"  :title=\"row.embedding\" >{{ truncate(row.embedding,  30) }}</td>\n          </tr>\n        </tbody>\n      </table>\n      <div class=\"rv-empty\" v-else><span>&#9711;</span><p>No records found.</p></div>\n    </div>\n    <div class=\"rv-pagination\" v-if=\"totalPages > 1\">\n      <button class=\"pg-btn\" @click=\"page = 1\"          :disabled=\"page === 1\">&#171;</button>\n      <button class=\"pg-btn\" @click=\"page--\"            :disabled=\"page === 1\">&#8249;</button>\n      <span class=\"pg-info\">Page {{ page }} of {{ totalPages }}</span>\n      <button class=\"pg-btn\" @click=\"page++\"            :disabled=\"page === totalPages\">&#8250;</button>\n      <button class=\"pg-btn\" @click=\"page = totalPages\" :disabled=\"page === totalPages\">&#187;</button>\n      <select class=\"pg-size\" v-model=\"pageSize\">\n        <option :value=\"10\">10 / page</option>\n        <option :value=\"25\">25 / page</option>\n        <option :value=\"50\">50 / page</option>\n      </select>\n    </div>\n  </div>\n</template>\n\n<script>\nexport default {\n  data() {\n    return { rows: [], search: '', sortKey: 'id', sortDir: 1, page: 1, pageSize: 10 };\n  },\n  computed: {\n    filtered() {\n      const q = this.search.toLowerCase();\n      const data = q ? this.rows.filter(r =>\n        (r.first_name||'').toLowerCase().includes(q) ||\n        (r.last_name||'').toLowerCase().includes(q)  ||\n        (r.status||'').toLowerCase().includes(q)     ||\n        String(r.id).includes(q)\n      ) : this.rows;\n      return [...data].sort((a, b) => {\n        const av = a[this.sortKey] ?? '';\n        const bv = b[this.sortKey] ?? '';\n        return av < bv ? -this.sortDir : av > bv ? this.sortDir : 0;\n      });\n    },\n    totalPages() { return Math.max(1, Math.ceil(this.filtered.length / this.pageSize)); },\n    paginated() { const s = (this.page - 1) * this.pageSize; return this.filtered.slice(s, s + this.pageSize); }\n  },\n  watch: {\n    msg(newMsg) {\n      if (!newMsg) return;\n      if (newMsg.topic === 'table_data') {\n        this.rows = newMsg.payload || [];\n      }\n    },\n    search()   { this.page = 1; },\n    pageSize() { this.page = 1; }\n  },\n  mounted() {\n    this.load();\n  },\n  methods: {\n    load() { this.send({ topic: 'load_table', payload: null }); },\n    sortBy(key) {\n      if (this.sortKey === key) { this.sortDir *= -1; }\n      else { this.sortKey = key; this.sortDir = 1; }\n    },\n    sortIcon(key) { if (this.sortKey !== key) return '⇅'; return this.sortDir === 1 ? '↑' : '↓'; },\n    truncate(str, n) { if (!str) return '—'; return str.length > n ? str.slice(0, n) + '…' : str; }\n  }\n};\n</script>\n\n<style>\n@import url('https://fonts.googleapis.com/css2?family=Share+Tech+Mono&family=Exo+2:wght@300;600;800&display=swap');\n.records-view * { box-sizing: border-box; margin: 0; padding: 0; }\n.records-view { background: #0a0a0f; color: #c8d8e8; font-family: 'Exo 2', sans-serif; padding: 20px 24px; border: 1px solid #1a2535; border-radius: 4px; min-height: 480px; display: flex; flex-direction: column; gap: 16px; position: relative; overflow: hidden; }\n.records-view::before { content: ''; position: absolute; inset: 0; background: repeating-linear-gradient(0deg, transparent, transparent 39px, #111827 40px); pointer-events: none; opacity: 0.2; }\n.rv-header { display: flex; align-items: center; justify-content: space-between; flex-wrap: wrap; gap: 12px; padding-bottom: 14px; border-bottom: 1px solid #1e2d40; position: relative; }\n.rv-title { font-size: 1.4rem; font-weight: 800; letter-spacing: 0.25em; text-transform: uppercase; color: #e0eaf5; }\n.rv-title span { color: #38bdf8; }\n.rv-controls { display: flex; align-items: center; gap: 12px; flex-wrap: wrap; }\n.rv-search { background: #060d16; border: 1px solid #1a2e44; color: #c8d8e8; padding: 7px 12px; font-family: 'Exo 2', sans-serif; font-size: 0.82rem; border-radius: 2px; outline: none; width: 220px; transition: border-color 0.2s; }\n.rv-search:focus { border-color: #38bdf8; }\n.rv-search::placeholder { color: #2a4060; }\n.rv-refresh { background: transparent; border: 1px solid #1e3a55; color: #38bdf8; font-family: 'Share Tech Mono', monospace; font-size: 0.7rem; letter-spacing: 0.12em; padding: 7px 14px; border-radius: 2px; cursor: pointer; transition: background 0.2s; }\n.rv-refresh:hover { background: #0f2035; }\n.rv-count { font-family: 'Share Tech Mono', monospace; font-size: 0.68rem; color: #3a5a7a; letter-spacing: 0.1em; }\n.rv-table-wrap { overflow-x: auto; flex: 1; position: relative; }\n.rv-table { width: 100%; border-collapse: collapse; font-size: 0.85rem; }\n.rv-table thead tr { border-bottom: 2px solid #1e3a55; }\n.rv-table th { font-family: 'Share Tech Mono', monospace; font-size: 0.62rem; letter-spacing: 0.2em; color: #3a5a7a; text-transform: uppercase; padding: 10px 14px; text-align: left; white-space: nowrap; user-select: none; }\n.rv-table th.sortable { cursor: pointer; }\n.rv-table th.sortable:hover { color: #38bdf8; }\n.sort-icon { margin-left: 4px; font-size: 0.65rem; opacity: 0.6; }\n.rv-table tbody tr { border-bottom: 1px solid #0f1a28; transition: background 0.15s; }\n.rv-table tbody tr:hover { background: #0d1a28; }\n.rv-table tbody tr.row-pending    { border-left: 2px solid #f59e0b33; }\n.rv-table tbody tr.row-identified { border-left: 2px solid #38bdf833; }\n.rv-table tbody tr.row-blacklisted { border-left: 2px solid #a855f733; }\n.pill.blacklisted { background: #2e106588; border-color: #a855f766; color: #a855f7; }\n.rv-table tbody tr.row-rejected   { border-left: 2px solid #ef444433; }\n.rv-table td { padding: 10px 14px; color: #8aaac8; vertical-align: middle; }\n.rv-table td.mono { font-family: 'Share Tech Mono', monospace; font-size: 0.75rem; }\n.path-cell, .emb-cell { color: #3a5a7a; max-width: 280px; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }\n.pill { display: inline-block; padding: 3px 10px; border-radius: 2px; font-family: 'Share Tech Mono', monospace; font-size: 0.62rem; letter-spacing: 0.15em; text-transform: uppercase; border: 1px solid #1e2d40; color: #555; }\n.pill.pending    { background: #2d1e0088; border-color: #f59e0b66; color: #f59e0b; }\n.pill.identified { background: #00203088; border-color: #38bdf866; color: #38bdf8; }\n.pill.verified   { background: #00201088; border-color: #22c55e66; color: #22c55e; }\n.pill.rejected   { background: #20001088; border-color: #ef444466; color: #ef4444; }\n.rv-empty { display: flex; flex-direction: column; align-items: center; justify-content: center; gap: 12px; min-height: 260px; color: #2a4060; }\n.rv-empty span { font-size: 2.5rem; }\n.rv-empty p { font-family: 'Share Tech Mono', monospace; font-size: 0.78rem; letter-spacing: 0.1em; }\n.rv-pagination { display: flex; align-items: center; gap: 6px; justify-content: flex-end; padding-top: 10px; border-top: 1px solid #1e2d40; position: relative; }\n.pg-btn { background: #0f1e2e; border: 1px solid #1e3a55; color: #38bdf8; width: 30px; height: 30px; border-radius: 2px; font-size: 0.9rem; cursor: pointer; transition: background 0.2s; }\n.pg-btn:hover:not(:disabled) { background: #162840; }\n.pg-btn:disabled { opacity: 0.25; cursor: default; }\n.pg-info { font-family: 'Share Tech Mono', monospace; font-size: 0.68rem; color: #3a5a7a; letter-spacing: 0.1em; padding: 0 6px; }\n.pg-size { background: #060d16; border: 1px solid #1a2e44; color: #6b8aaa; font-family: 'Share Tech Mono', monospace; font-size: 0.68rem; padding: 4px 8px; border-radius: 2px; margin-left: 8px; cursor: pointer; }\n</style>",
