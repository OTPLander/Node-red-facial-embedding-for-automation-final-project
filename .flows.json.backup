            ]
        ]
    },
    {
        "id": "2079967e09a28244",
        "type": "function",
        "z": "b31915b6cc494042",
        "name": "Ensure Table + Clean Nulls",
        "func": "const userDir = env.get(\"USERPROFILE\") || \"C:\";\nmsg.database = userDir + \"/saved_faces/face_data.db\";\n\nmsg.topic = `CREATE TABLE IF NOT EXISTS persons (\n    id         INTEGER PRIMARY KEY AUTOINCREMENT,\n    first_name TEXT,\n    last_name  TEXT,\n    photo_path TEXT,\n    embedding  TEXT,\n    status     TEXT\n);\nDELETE FROM persons\nWHERE first_name IS NULL\n  AND last_name  IS NULL\n  AND photo_path IS NULL;`;\nreturn msg;",
        "outputs": 1,
        "x": 650,
        "y": 220,
        "wires": [
            [
                "d265777c9b809965"
            ]
        ]
    },
    {
        "id": "d265777c9b809965",
