    {
        "id": "check_db_query",
        "type": "function",
        "z": "b31915b6cc494042",
        "name": "1. Save Data & Query DB",
        "func": "msg.new_face = msg.payload;\n\nif (msg.payload.status !== 'success') {\n    return null;\n}\n\nconst userDir = env.get(\"USERPROFILE\") || \"C:\";\nmsg.database = userDir + \"/saved_faces/face_data.db\";\nmsg.topic = \"SELECT id, embedding FROM persons WHERE embedding IS NOT NULL AND embedding != ''\";\n\nreturn msg;",
        "outputs": 1,
        "x": 230,
        "y": 440,
        "wires": [
            [
                "check_db_sqlite"
            ]
        ]
    },
    {
        "id": "check_db_sqlite",
        "type": "queuedsqlite",
        "z": "b31915b6cc494042",
        "mydb": "686b413b27a3785d",
        "sqlquery": "msg.topic",
        "dbName": "msg.database",
        "db": "",
        "sql": "",
        "name": "2. Get Saved Faces",
        "x": 460,
        "y": 440,
        "wires": [
            [
                "compare_faces"
            ]
        ]
    },
    {
        "id": "compare_faces",
        "type": "function",
        "z": "b31915b6cc494042",
        "name": "3. Compare Embeddings",
        "func": "const existingFaces = msg.payload;\nconst newEmbedding = msg.new_face.embedding;\n\n// UMBRAL DE SIMILITUD EXACTO DE TU SCRIPT DE PYTHON\nconst THRESHOLD = 0.40; \n\n// Función para calcular la Distancia Coseno (equivalente a tu código de Numpy)\nfunction cosineDistance(vecA, vecB) {\n    let dotProduct = 0;\n    let normA = 0;\n    let normB = 0;\n    \n    for (let i = 0; i < vecA.length; i++) {\n        dotProduct += vecA[i] * vecB[i];\n        normA += vecA[i] * vecA[i];\n        normB += vecB[i] * vecB[i];\n    }\n    \n    if (normA === 0 || normB === 0) return 1; // Evitar división por cero\n    \n    return 1 - (dotProduct / (Math.sqrt(normA) * Math.sqrt(normB)));\n}\n\nlet isDuplicate = false;\nlet matchedId = null;\n\nfor (let face of existingFaces) {\n    try {\n        let dbEmbedding = JSON.parse(face.embedding);\n        \n        // Usamos Distancia Coseno en lugar de Euclidiana\n        let distance = cosineDistance(newEmbedding, dbEmbedding);\n        \n        if (distance < THRESHOLD) {\n            isDuplicate = true;\n            matchedId = face.id;\n            break; // ¡Encontrado! Dejamos de buscar.\n        }\n    } catch(e) {\n        // Ignorar si un embedding antiguo está corrupto\n    }\n}\n\n// Restauramos el payload original para no romper el resto del flujo\nmsg.payload = msg.new_face;\nmsg.match_info = {\n    isDuplicate: isDuplicate,\n    matchedId: matchedId\n};\n\nreturn msg;",
        "outputs": 1,
        "timeout": "",
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
        "x": 680,
        "y": 440,
        "wires": [
            [
                "branch_duplicate"
            ]
        ]
    },
    {
        "id": "branch_duplicate",
        "type": "switch",
        "z": "b31915b6cc494042",
        "name": "Is Duplicate?",
        "property": "match_info.isDuplicate",
        "propertyType": "msg",
        "rules": [
            {
                "t": "true"
            },
            {
                "t": "false"
            }
        ],
        "checkall": "true",
        "repair": false,
