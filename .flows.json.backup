    {
        "id": "2fea4c1170ec2f8d",
        "type": "function",
        "z": "b31915b6cc494042",
        "name": "Auto-Install & Boot API",
        "func": "const userDir = env.get(\"USERPROFILE\") || \"C:\";\nconst projectDir = userDir + \"\\\\.node-red\\\\projects\\\\face-registration-system\";\nconst weightsDir = userDir + \"\\\\.deepface\\\\weights\";\nconst weightsFile = weightsDir + \"\\\\facenet_weights.h5\";\nconst weightsUrl = \"https://github.com/serengil/deepface_models/releases/download/v1.0/facenet_weights.h5\";\n\n// 1. SIN PARÉNTESIS y usando 'call' para que NPM no se trague caracteres extraños\nlet cmd = `where pm2 >nul 2>nul || call npm install -g pm2`;\n\n// 2. Pre-descarga del modelo Facenet de DeepFace\ncmd += ` && if not exist \"${weightsDir}\" mkdir \"${weightsDir}\"`;\ncmd += ` && if not exist \"${weightsFile}\" curl -# -L -o \"${weightsFile}\" \"${weightsUrl}\"`;\n\n// 3. Arranque del backend\ncmd += ` && cd \"${projectDir}\"`;\n\n// 4. PIP install (también sin paréntesis para no tentar a la suerte)\ncmd += ` && if exist requirements.txt pip install -r requirements.txt`;\n\n// 5. PM2 con 'call' para evitar que Windows rompa la cadena\ncmd += ` && call pm2 restart face-api || call pm2 start api.py --name face-api --interpreter python`;\n\nmsg.payload = cmd;\nreturn msg;",
        "outputs": 1,
        "timeout": "",
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
        "x": 380,
