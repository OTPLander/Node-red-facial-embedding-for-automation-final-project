    {
        "id": "0dabfb7e0453066a",
        "type": "function",
        "z": "b31915b6cc494042",
        "name": "Build file path",
        "func": "const filename = msg.req.params.filename;\n// Strip any path traversal for safety\nconst safe = filename.replace(/[^a-zA-Z0-9_\\-\\.]/g, '');\n\nlet userDir = env.get(\"USERPROFILE\") || \"C:\";\nmsg.filename = userDir + '/saved_faces/' + safe;\n\nreturn msg;",
        "outputs": 1,
        "timeout": "",
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
        "x": 310,
        "y": 1300,
