                "check_db_sqlite"
            ]
        ]
    },
    {
        "id": "681eed3bcfb276b8",
        "type": "function",
        "z": "b31915b6cc494042",
        "name": "3. Compare Embeddings",
        "func": "const existingFaces = msg.payload;\nconst newEmbedding = msg.new_face.embedding;\n\nconst THRESHOLD = 0.40; \n\nfunction cosineDistance(vecA, vecB) {\n    let dotProduct = 0;\n    let normA = 0;\n    let normB = 0;\n    \n    for (let i = 0; i < vecA.length; i++) {\n        dotProduct += vecA[i] * vecB[i];\n        normA += vecA[i] * vecA[i];\n        normB += vecB[i] * vecB[i];\n    }\n    \n    if (normA === 0 || normB === 0) return 1; \n    \n    return 1 - (dotProduct / (Math.sqrt(normA) * Math.sqrt(normB)));\n}\n\nlet isDuplicate = false;\nlet matchedId = null;\nlet matchedStatus = null; // Variable nueva para guardar el estado\n\nfor (let face of existingFaces) {\n    try {\n        let dbEmbedding = JSON.parse(face.embedding);\n        let distance = cosineDistance(newEmbedding, dbEmbedding);\n        \n        if (distance < THRESHOLD) {\n            isDuplicate = true;\n            matchedId = face.id;\n            matchedStatus = face.status; // Extraemos el estado de la DB en el acto\n            break; \n        }\n    } catch(e) {}\n}\n\nmsg.payload = msg.new_face;\nmsg.match_info = {\n    isDuplicate: isDuplicate,\n    matchedId: matchedId,\n    matchedStatus: matchedStatus // Lo pasamos al siguiente nodo\n};\n\nreturn msg;",
        "outputs": 1,
        "timeout": "",
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
        "x": 630,
        "y": 720,
        "wires": [
            [
                "branch_duplicate"
            ]
        ]
    },
    {
        "id": "12483c9c542d83d7",
        "type": "OPCUA-IIoT-Write",
        "z": "b31915b6cc494042",
        "connector": "c6a66b5d3bc08639",
        "name": "Trigger iFacialDetec",
        "justValue": false,
        "showStatusActivities": false,
        "showErrors": true,
        "x": 1600,
        "y": 720,
