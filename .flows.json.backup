        "type": "function",
        "z": "b31915b6cc494042",
        "name": "Is Blacklisted?",
        "func": "// 1. Normalizamos el texto de SQLite\nlet currentStatus = (msg.match_info.matchedStatus || \"\").toString().trim().toLowerCase();\n\nif (currentStatus === 'blacklisted') {\n    // 2. LA OPCIÓN NUCLEAR: Le damos TODO mascado al nodo OPC UA Write\n    // Definimos qué variable es Y su valor exacto en el mismo paquete.\n    msg.payload = {\n        injectType: \"write\",\n        addressSpaceItems: [\n            {\n                name: \"Detec_Alert\",\n                nodeId: \"ns=4;s=MAIN.stSystem.inputs.iFacialDetec\",\n                datatypeName: \"Boolean\"\n            }\n        ],\n        valuesToWrite: [true]\n    };\n    \n    return msg;\n}\n\n// Si no es blacklisted, detenemos el flujo\nreturn null;",
        "outputs": 1,
        "timeout": 0,
        "noerr": 0,
