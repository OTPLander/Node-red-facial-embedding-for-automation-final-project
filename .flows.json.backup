    {
        "id": "58e521646670c8fb",
        "type": "switch",
        "z": "b31915b6cc494042",
        "name": "Route by Topic",
        "property": "topic",
        "propertyType": "msg",
        "rules": [
            {
                "t": "eq",
                "v": "load_faces",
                "vt": "str"
            },
            {
                "t": "eq",
                "v": "save_face",
