    {
        "id": "3aa4c2141cf959ac",
        "type": "inject",
        "z": "b31915b6cc494042",
        "name": "1. Initialize Database",
        "props": [
            {
                "p": "payload"
            }
        ],
        "repeat": "",
        "crontab": "",
        "once": false,
        "topic": "",
        "payload": "",
