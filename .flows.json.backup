    {
        "id": "2362aaf9df236738",
        "type": "function",
        "z": "b31915b6cc494042",
        "name": "Build SELECT Query",
        "func": "const d = msg.payload;\n\nconst userDir = env.get(\"USERPROFILE\") || \"C:\";\nmsg.database = userDir + \"/saved_faces/face_data.db\";\n\nif (d.status === 'rejected') {\n    // Si lo rechazas, borramos el registro por completo\n    msg.topic = `DELETE FROM persons WHERE id=${d.id}`;\n} else {\n    // Si es identified o blacklisted, lo actualizamos con sus datos\n    const fn = d.first_name || '';\n    const ln = d.last_name || '';\n    msg.topic = `UPDATE persons SET first_name='${fn}', last_name='${ln}', status='${d.status}' WHERE id=${d.id}`;\n}\n\nreturn msg;",
        "outputs": 1,
        "timeout": "",
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
        "x": 750,
        "y": 800,
        "wires": [
