    {
        "id": "8a6bdf124879e6ca",
        "type": "ui-template",
        "z": "b31915b6cc494042",
        "group": "face_register_group",
        "page": "",
        "ui": "",
        "name": "Face Registration System",
        "order": 1,
        "width": "24",
        "height": "14",
        "head": "",
        "format": "<template>\n  <div class=\"face-registry\">\n    <div class=\"header\">\n      <div class=\"header-left\">\n        <span class=\"badge\" v-if=\"faces.length > 0\">{{ currentIndex + 1 }} / {{ faces.length }}</span>\n        <span class=\"badge empty\" v-else>No records</span>\n      </div>\n      <h1 class=\"title\">FACE <span>REGISTRY</span></h1>\n      <div class=\"header-right\">\n        <span class=\"status-dot\" :class=\"faces[currentIndex] && faces[currentIndex].status\"></span>\n        <span class=\"status-label\">{{ faces[currentIndex] ? faces[currentIndex].status : '—' }}</span>\n      </div>\n    </div>\n    <div class=\"main\" v-if=\"faces.length > 0\">\n      <div class=\"image-panel\">\n        <button class=\"nav-btn\" @click=\"prev\" :disabled=\"currentIndex === 0\">&#8592;</button>\n        <div class=\"image-wrapper\">\n          <img v-if=\"faces[currentIndex].photo_path\" :src=\"'/faces/' + getFilename(faces[currentIndex].photo_path)\"\n               @error=\"onImgError($event)\"\n               class=\"face-img\" />\n          <div class=\"img-overlay\" :class=\"faces[currentIndex].status\">{{ faces[currentIndex].status }}</div>\n        </div>\n        <button class=\"nav-btn\" @click=\"next\" :disabled=\"currentIndex === faces.length - 1\">&#8594;</button>\n      </div>\n      <div class=\"form-panel\">\n        <div class=\"field-row\">\n          <div class=\"field\">\n            <label>FIRST NAME</label>\n            <input v-model=\"form.first_name\" placeholder=\"Enter first name\" />\n          </div>\n          <div class=\"field\">\n            <label>LAST NAME</label>\n            <input v-model=\"form.last_name\" placeholder=\"Enter last name\" />\n          </div>\n        </div>\n        <div class=\"field\">\n          <label>RECORD ID</label>\n          <input :value=\"faces[currentIndex].id\" disabled class=\"disabled-input\" />\n        </div>\n        <div class=\"field\">\n          <label>PHOTO PATH</label>\n          <input :value=\"faces[currentIndex].photo_path\" disabled class=\"disabled-input path-input\" />\n        </div>\n        <div class=\"field\">\n          <label>SET STATUS</label>\n          <div class=\"status-selector\">\n            <button v-for=\"s in statuses\" :key=\"s\"\n                    class=\"status-btn\"\n                    :class=\"{ active: form.status === s, [s]: true }\"\n                    @click=\"form.status = s\">{{ s }}\n            </button>\n          </div>\n        </div>\n        <div class=\"actions\">\n          <button class=\"btn-reset\" @click=\"resetForm\">RESET</button>\n          <button class=\"btn-save\" @click=\"save\" :disabled=\"saving\">\n            <span v-if=\"saving\">SAVING...</span>\n            <span v-else>SAVE RECORD</span>\n          </button>\n        </div>\n        <div class=\"toast\" :class=\"{ visible: toast.show, [toast.type]: true }\">{{ toast.message }}</div>\n      </div>\n    </div>\n    <div class=\"empty-state\" v-else>\n      <div class=\"empty-icon\">&#9711;</div>\n      <p>No pending faces found in the database.</p>\n      <button class=\"btn-save\" @click=\"loadFaces\">REFRESH</button>\n    </div>\n  </div>\n</template>\n\n<script>\nexport default {\n  data() {\n    return {\n      faces: [],\n      currentIndex: 0,\n      statuses: ['pending', 'identified', 'rejected', 'blacklisted'],\n      form: { first_name: '', last_name: '', status: 'pending' },\n      saving: false,\n      toast: { show: false, message: '', type: 'success' }\n    };\n  },\n  watch: {\n    msg(newMsg) {\n      if (!newMsg) return;\n      if (newMsg.topic === 'faces_data') {\n        this.faces = newMsg.payload || [];\n        this.currentIndex = 0;\n        this.syncForm();\n        this.saving = false;\n      } else if (newMsg.topic === 'save_result') {\n        this.saving = false;\n        if (newMsg.payload && newMsg.payload.success) {\n          this.showToast('Record updated!', 'success');\n          // Eliminamos la cara de la vista actual para pasar a la siguiente automáticamente\n          this.faces.splice(this.currentIndex, 1);\n          if (this.currentIndex >= this.faces.length && this.currentIndex > 0) {\n              this.currentIndex--;\n          }\n          this.syncForm();\n        } else {\n          this.showToast('Error saving record.', 'error');\n        }\n      }\n    }\n  },\n  mounted() { this.loadFaces(); },\n  methods: {\n    loadFaces() { this.send({ topic: 'load_faces', payload: null }); },\n    prev() { if (this.currentIndex > 0) { this.currentIndex--; this.syncForm(); } },\n    next() { if (this.currentIndex < this.faces.length - 1) { this.currentIndex++; this.syncForm(); } },\n    syncForm() {\n      const f = this.faces[this.currentIndex];\n      if (f) {\n        this.form.first_name = f.first_name || '';\n        this.form.last_name  = f.last_name  || '';\n        this.form.status     = f.status     || 'pending';\n      }\n    },\n    save() {\n      const face = this.faces[this.currentIndex];\n      this.saving = true;\n      this.send({ topic: 'save_face', payload: { id: face.id, first_name: this.form.first_name, last_name: this.form.last_name, status: this.form.status } });\n    },\n    resetForm() { this.syncForm(); },\n    getFilename(path) {\n      if (!path) return '';\n      return path.replace(/\\\\/g, '/').split('/').pop();\n    },\n    onImgError(e) {\n      e.target.src = 'data:image/svg+xml,<svg xmlns=\"http://www.w3.org/2000/svg\" width=\"200\" height=\"200\"><rect fill=\"%23111\" width=\"200\" height=\"200\"/><text x=\"50%\" y=\"50%\" fill=\"%23555\" font-size=\"14\" text-anchor=\"middle\" dy=\".3em\">NO IMAGE</text></svg>';\n    },\n    showToast(message, type) {\n      this.toast = { show: true, message, type };\n      setTimeout(() => { this.toast.show = false; }, 3000);\n    }\n  }\n};\n</script>\n\n<style>\n@import url('https://fonts.googleapis.com/css2?family=Share+Tech+Mono&family=Exo+2:wght@300;600;800&display=swap');\n.face-registry * { box-sizing: border-box; margin: 0; padding: 0; }\n.face-registry { background: #0a0a0f; color: #c8d8e8; font-family: 'Exo 2', sans-serif; min-height: 480px; padding: 20px 24px; border: 1px solid #1a2535; border-radius: 4px; position: relative; overflow: hidden; }\n.face-registry::before { content: ''; position: absolute; top: 0; left: 0; right: 0; bottom: 0; background: repeating-linear-gradient(0deg, transparent, transparent 39px, #111827 40px); pointer-events: none; opacity: 0.25; }\n.header { display: flex; align-items: center; justify-content: space-between; margin-bottom: 20px; padding-bottom: 14px; border-bottom: 1px solid #1e2d40; }\n.title { font-size: 1.4rem; font-weight: 800; letter-spacing: 0.25em; text-transform: uppercase; color: #e0eaf5; }\n.title span { color: #38bdf8; }\n.badge { font-family: 'Share Tech Mono', monospace; font-size: 0.75rem; background: #0f2035; border: 1px solid #1e3a55; color: #38bdf8; padding: 3px 10px; border-radius: 2px; letter-spacing: 0.1em; }\n.badge.empty { color: #555; border-color: #222; }\n.header-right { display: flex; align-items: center; gap: 8px; }\n.status-dot { width: 9px; height: 9px; border-radius: 50%; background: #555; }\n.status-dot.pending { background: #f59e0b; box-shadow: 0 0 8px #f59e0b88; }\n.status-dot.identified { background: #38bdf8; box-shadow: 0 0 8px #38bdf888; }\n.status-dot.blacklisted { background: #a855f7; box-shadow: 0 0 8px #a855f788; }\n.status-dot.rejected { background: #ef4444; box-shadow: 0 0 8px #ef444488; }\n.status-label { font-family: 'Share Tech Mono', monospace; font-size: 0.7rem; text-transform: uppercase; letter-spacing: 0.12em; color: #6b8aaa; }\n.main { display: flex; gap: 28px; align-items: flex-start; }\n.image-panel { display: flex; align-items: center; gap: 10px; flex-shrink: 0; }\n.image-wrapper { position: relative; width: 200px; height: 220px; border: 1px solid #1e2d40; border-radius: 3px; overflow: hidden; background: #060b12; }\n.face-img { width: 100%; height: 100%; object-fit: cover; display: block; filter: contrast(1.05) saturate(0.9); transition: filter 0.3s; }\n.image-wrapper:hover .face-img { filter: contrast(1.1) saturate(1); }\n.img-overlay { position: absolute; bottom: 0; left: 0; right: 0; padding: 5px 0; text-align: center; font-family: 'Share Tech Mono', monospace; font-size: 0.65rem; letter-spacing: 0.2em; text-transform: uppercase; background: rgba(0,0,0,0.72); color: #555; }\n.img-overlay.pending { color: #f59e0b; }\n.img-overlay.identified { color: #38bdf8; }\n.img-overlay.blacklisted { color: #a855f7; }\n.img-overlay.rejected { color: #ef4444; }\n.nav-btn { background: #0f1e2e; border: 1px solid #1e3a55; color: #38bdf8; width: 34px; height: 34px; border-radius: 3px; font-size: 1.1rem; cursor: pointer; transition: background 0.2s, transform 0.1s; flex-shrink: 0; }\n.nav-btn:hover:not(:disabled) { background: #162840; transform: scale(1.08); }\n.nav-btn:disabled { opacity: 0.2; cursor: default; }\n.form-panel { flex: 1; display: flex; flex-direction: column; gap: 14px; }\n.field-row { display: flex; gap: 14px; }\n.field { display: flex; flex-direction: column; gap: 5px; flex: 1; }\n.field label { font-family: 'Share Tech Mono', monospace; font-size: 0.62rem; letter-spacing: 0.2em; color: #3a5a7a; text-transform: uppercase; }\n.field input { background: #060d16; border: 1px solid #1a2e44; color: #c8d8e8; padding: 9px 12px; font-family: 'Exo 2', sans-serif; font-size: 0.88rem; border-radius: 2px; outline: none; transition: border-color 0.2s, box-shadow 0.2s; }\n.field input:focus { border-color: #38bdf8; box-shadow: 0 0 0 2px #38bdf820; }\n.disabled-input { opacity: 0.4; cursor: not-allowed; }\n.path-input { font-family: 'Share Tech Mono', monospace; font-size: 0.7rem; }\n.status-selector { display: flex; gap: 8px; flex-wrap: wrap; }\n.status-btn { padding: 6px 14px; border-radius: 2px; border: 1px solid #1e2d40; background: #060d16; color: #4a6a8a; font-family: 'Share Tech Mono', monospace; font-size: 0.68rem; letter-spacing: 0.15em; text-transform: uppercase; cursor: pointer; transition: all 0.2s; }\n.status-btn:hover { border-color: #38bdf8; color: #38bdf8; }\n.status-btn.active.pending { background: #2d1e00; border-color: #f59e0b; color: #f59e0b; }\n.status-btn.active.identified { background: #002030; border-color: #38bdf8; color: #38bdf8; }\n.status-btn.active.blacklisted { background: #2e1065; border-color: #a855f7; color: #a855f7; }\n.status-btn.active.rejected { background: #200010; border-color: #ef4444; color: #ef4444; }\n.actions { display: flex; gap: 12px; margin-top: 4px; }\n.btn-save { flex: 1; padding: 11px; background: #38bdf8; color: #050d16; font-family: 'Exo 2', sans-serif; font-weight: 800; font-size: 0.8rem; letter-spacing: 0.2em; text-transform: uppercase; border: none; border-radius: 2px; cursor: pointer; transition: background 0.2s, transform 0.1s; }\n.btn-save:hover:not(:disabled) { background: #7dd3f8; transform: translateY(-1px); }\n.btn-save:disabled { opacity: 0.5; cursor: not-allowed; }\n.btn-reset { padding: 11px 20px; background: transparent; border: 1px solid #1e3a55; color: #4a6a8a; font-family: 'Exo 2', sans-serif; font-weight: 600; font-size: 0.8rem; letter-spacing: 0.15em; text-transform: uppercase; border-radius: 2px; cursor: pointer; transition: all 0.2s; }\n.btn-reset:hover { border-color: #38bdf8; color: #38bdf8; }\n.toast { position: absolute; bottom: 20px; right: 24px; padding: 9px 18px; border-radius: 2px; font-family: 'Share Tech Mono', monospace; font-size: 0.72rem; letter-spacing: 0.12em; opacity: 0; transform: translateY(8px); transition: opacity 0.3s, transform 0.3s; pointer-events: none; }\n.toast.visible { opacity: 1; transform: translateY(0); }\n.toast.success { background: #002010; border: 1px solid #22c55e; color: #22c55e; }\n.toast.error { background: #200010; border: 1px solid #ef4444; color: #ef4444; }\n.empty-state { display: flex; flex-direction: column; align-items: center; justify-content: center; gap: 16px; min-height: 300px; color: #2a4060; }\n.empty-icon { font-size: 3rem; }\n.empty-state p { font-family: 'Share Tech Mono', monospace; font-size: 0.8rem; letter-spacing: 0.1em; }\n</style>",
        "storeOutMessages": true,
